{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "array",
    "description": "Array of mission objects",
    "items": {
        "type": "object",
        "required": [
            "slug",
            "chapter_id",
            "chapter_title",
            "level",
            "name"
        ],
        "properties": {
            "slug": {
                "type": "string",
                "description": "Mission identifier in format 'chapter-mission' (e.g., '1-1')",
                "pattern": "^\\d+-\\d+$"
            },
            "chapter_id": {
                "type": "integer",
                "description": "Chapter number",
                "minimum": 1
            },
            "chapter_title": {
                "type": "string",
                "description": "Title of the chapter"
            },
            "level": {
                "type": "integer",
                "description": "Mission number within the chapter",
                "minimum": 1
            },
            "name": {
                "type": "string",
                "description": "Name of the mission"
            },
            "energy_cost": {
                "type": "integer",
                "description": "The energy cost to battle/raid the mission",
                "minimum": 0
            },
            "hero_slug": {
                "type": "string",
                "description": "Optional hero slug for the mission"
            }
        },
        "additionalProperties": false
    }
}