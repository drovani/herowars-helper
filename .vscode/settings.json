{
  "typescript.tsdk": "node_modules/typescript/lib",
  "json.schemas": [
    {
      "fileMatch": [
        "equipments.json"
      ],
      "url": "./app/data/equipment-schema.json"
    },
    {
      "fileMatch": [
        "missions.json"
      ],
      "url": "./app/data/missions-schema.json"
    },
    {
      "fileMatch": [
        "heroes.json"
      ],
      "url": "./app/data/hero-schema.json"
    }
  ],
  "files.exclude": {
    "**/.git": true,
    "**/.netlify": true,
    "**/.react-router": true,
    "**/supabase/.branches": true,
    "**/supabase/.temp": true
  },
  "explorer.excludeGitIgnore": false,
  "postman.settings.dotenv-detection-notification-visibility": false
}